# ─────────────────────────────────────────────
# VaccinationBD Centers — Environment Variables
# Port: 3002
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────
# Secret used to sign JWT session tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Canonical URL of this app — must match the running port
NEXTAUTH_URL=http://localhost:3002

# ── MongoDB Atlas ─────────────────────────────
# Shared vaccinationDB cluster URI (same DB used by admin + citizen apps)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vaccinationDB
MONGODB_URI=

# ── Google Maps ───────────────────────────────
# Used for center location display on maps (public — safe to expose)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Cron Jobs ─────────────────────────────────
# Bearer token to protect internal cron API routes from unauthorized calls
CRON_SECRET=

# ── Audit System ──────────────────────────────
# Internal secret shared between Edge middleware and the audit-event API route.
# Prevents external callers from writing fake auth audit events.
# Generate with: openssl rand -base64 32
AUDIT_INTERNAL_SECRET=

# ── Web Push / VAPID ─────────────────────────────
# Generate keys (one-time): npx web-push generate-vapid-keys
# Paste the output below. Public key is safe to expose.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@vaccinationbd.gov.bd

# ── Email (OTP / alerts via Gmail SMTP) ───────
GMAIL_USER=
GMAIL_APP_PASSWORD=
